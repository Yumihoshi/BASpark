<Window x:Class="BASpark.ControlPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BASpark - 控制面板" Height="650" Width="680"
        WindowStartupLocation="CenterScreen" Background="#F5F7FA" Icon="app.ico">
    
    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Name="b" CornerRadius="5" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#45AFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E0F2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator x:Name="RootBullet" Background="Transparent" Cursor="Hand">
                            <BulletDecorator.Bullet>
                                <Grid Width="40" Height="20">
                                    <Border x:Name="Background" Background="#DDD" CornerRadius="10" />
                                    <Border x:Name="Dot" Width="14" Height="14" Background="White" CornerRadius="7" HorizontalAlignment="Left" Margin="3,0">
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="Trans" X="0"/>
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="#45AFFF"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Trans" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Trans" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Background" Property="Background" Value="#E0E0E0"/>
                                <Setter TargetName="Dot" Property="Background" Value="#F5F5F5"/>
                                <Setter TargetName="RootBullet" Property="Cursor" Value="No"/>
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,30,0,0">
                <TextBlock Text="✨ BASpark" FontSize="20" FontWeight="Bold" Foreground="#45AFFF" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                <RadioButton Name="TabWelcome" Content="首页" Style="{StaticResource NavBtn}" IsChecked="True" Click="Tab_Click"/>
                <RadioButton Name="TabSettings" Content="设置" Style="{StaticResource NavBtn}" Click="Tab_Click"/>
                <RadioButton Name="TabAbout" Content="关于" Style="{StaticResource NavBtn}" Click="Tab_Click"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="30">
                
                <StackPanel Name="PageWelcome">
                    <Border x:Name="NoticeBar" Visibility="Collapsed" Background="#E3F2FD" CornerRadius="10" Padding="15" Margin="0,0,0,20" BorderBrush="#90CAF9" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📢" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="NoticeTitle" Text="加载中..." FontWeight="Bold" Foreground="#1976D2" FontSize="14"/>
                                <TextBlock x:Name="NoticeContent" Text="..." Margin="0,5,0,0" TextWrapping="Wrap" Foreground="#424242" FontSize="13" LineHeight="18"/>
                            </StackPanel>
                            <TextBlock x:Name="NoticeDate" Grid.Column="2" Text="" Foreground="#90CAF9" FontSize="10" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="欢迎回来，老师！" FontSize="28" FontWeight="Bold" Foreground="#333" Margin="0,0,0,5"/>
                    <TextBlock Text="Sensei, welcome back!" FontSize="12" Foreground="#999" Margin="0,0,0,25"/>

                    <Border Background="#EBF5FF" CornerRadius="12" Padding="20" HorizontalAlignment="Left" MinWidth="300">
                        <StackPanel>
                            <TextBlock Text="实时统计" FontSize="14" FontWeight="Bold" Foreground="#45AFFF" Margin="0,0,0,15"/>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="当前状态:" Foreground="#666"/>
                                <TextBlock x:Name="StatusText" Text="工作中" HorizontalAlignment="Right" FontWeight="Bold" Foreground="Green"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="累计点击次数:" Foreground="#666"/>
                                <TextBlock x:Name="ClickCountText" Text="0 次" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="#333"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Name="PageSettings" Visibility="Collapsed">
                    <TextBlock Text="参数配置" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>

                    <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="#EAECEF" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="基础设置" FontSize="14" FontWeight="Bold" Foreground="#45AFFF" Margin="0,0,0,12"/>
                            <CheckBox Name="CheckMasterSwitch" Content="启用鼠标点击特效" Style="{StaticResource ToggleSwitch}" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <CheckBox Name="CheckAlwaysTrailEffectSwitch" Content="启用鼠标常驻拖尾" Style="{StaticResource ToggleSwitch}" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <CheckBox Name="CheckAutoStart" Content="开机自动启动" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,8" Checked="CheckAutoStart_Changed" Unchecked="CheckAutoStart_Changed"/>
                            <CheckBox Name="CheckStartSilent" Content="静默启动 (最小化到托盘)" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,8"/>
                            <CheckBox Name="CheckTelemetry" Content="允许发送匿名运行数据以改进软件" Style="{StaticResource ToggleSwitch}" FontSize="12"/>

                            <Separator Background="#F0F2F5" Margin="0,4,0,12"/>
                            
                            <TextBlock Text="特效主题颜色" Foreground="#666" Margin="0,0,0,8" FontSize="12"/>
                            <StackPanel Orientation="Horizontal">
                                <Border Name="ColorPreview" Width="40" Height="28" CornerRadius="6" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,10,0"/>
                                <Button Content="更改颜色" Click="PickColor_Click" Width="90" Height="28" Background="#F8FAFF" BorderBrush="#45AFFF" Foreground="#45AFFF" Cursor="Hand" FontSize="12">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="#EAECEF" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="视觉表现" FontSize="14" FontWeight="Bold" Foreground="#45AFFF" Margin="0,0,0,16"/>
                            
                            <Grid Margin="0,0,0,15">
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="缩放比例" Foreground="#555" FontSize="13"/>
                                    <TextBlock Name="TextScaleValue" Text="1.0x" Foreground="#45AFFF" Margin="8,0,0,0" FontWeight="Bold"/>
                                </StackPanel>
                                <Slider Name="SliderScale" Grid.Row="1" Minimum="0.5" Maximum="3.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="EffectSlider_ValueChanged"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="全局不透明度" Foreground="#555" FontSize="13"/>
                                    <TextBlock Name="TextOpacityValue" Text="100%" Foreground="#45AFFF" Margin="8,0,0,0" FontWeight="Bold"/>
                                </StackPanel>
                                <Slider Name="SliderOpacity" Grid.Row="1" Minimum="0.1" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="EffectSlider_ValueChanged"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="动画播放速度" Foreground="#555" FontSize="13"/>
                                    <TextBlock Name="TextSpeedValue" Text="1.0x" Foreground="#45AFFF" Margin="8,0,0,0" FontWeight="Bold"/>
                                </StackPanel>
                                <Slider Name="SliderSpeed" Grid.Row="1" Minimum="0.2" Maximum="3.0" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="EffectSlider_ValueChanged"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="拖尾刷新率 (Hz)" Foreground="#555" FontSize="13"/>
                                    <TextBlock Name="TextTrailRefreshValue" Text="100%" Foreground="#45AFFF" Margin="8,0,0,0" FontWeight="Bold"/>
                                </StackPanel>
                                <Slider Name="SliderTrailRefresh" Grid.Row="1" Minimum="10" Maximum="240" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="EffectSlider_ValueChanged"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,16" BorderBrush="#EAECEF" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="环境过滤" FontSize="14" FontWeight="Bold" Foreground="#45AFFF" Margin="0,0,0,12"/>
                            
                            <CheckBox Name="CheckEnvironmentFilter" Content="启用智能环境探测" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,10" Checked="EnvironmentFilterSetting_Changed" Unchecked="EnvironmentFilterSetting_Changed"/>
                            <CheckBox Name="CheckHideInFullscreen" Content="全屏应用前台运行时自动暂停" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,15"/>

                            <Separator Background="#F0F2F5" Margin="0,5,0,15"/>

                            <TextBlock Text="应用过滤 (名单管理)" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                            <ComboBox Name="ComboProcessFilterMode" Width="180" Margin="0,0,0,12" SelectionChanged="ProcessFilterMode_Changed" Height="28" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="🚫 关闭过滤" Tag="Disabled"/>
                                <ComboBoxItem Content="❌ 黑名单模式" Tag="Blacklist"/>
                                <ComboBoxItem Content="✅ 白名单模式" Tag="Whitelist"/>
                            </ComboBox>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox x:Name="SearchProcess" Height="30" Padding="26,0,5,0" VerticalContentAlignment="Center" TextChanged="SearchProcess_TextChanged" Background="#F8FAFF" BorderBrush="#D6DEE8">
                                    <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></TextBox.Resources>
                                </TextBox>
                                <TextBlock Text="🔍" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8,0,0,0" Foreground="#AAA" IsHitTestVisible="False"/>
                                <Button Grid.Column="1" Content="刷新列表" Margin="8,0,0,0" Padding="12,0" Height="30" Click="RefreshProcessList_Click" Background="White">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                </Button>
                            </Grid>
                            
                            <ListBox Name="ListProcessSelection" Height="140" Background="#FDFDFF" BorderBrush="#E0E8F0" BorderThickness="1">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Margin="2,4" VerticalContentAlignment="Center">
                                            <StackPanel Orientation="Vertical" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" Foreground="#333"/>
                                                <TextBlock Text="{Binding ProcessName}" FontSize="10" Foreground="#999"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                    
                    <Button Content="应用更改" Click="SaveSettings_Click" Width="180" Height="42" Background="#45AFFF" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" FontWeight="Bold" FontSize="15">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                        </Button.Effect>
                    </Button>
                    <Rectangle Height="40"/>
                </StackPanel>

                <StackPanel Name="PageAbout" Visibility="Collapsed">
                    <TextBlock Text="关于" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                            <Run Text="BASpark "/>
                            <Run x:Name="VersionText" Text="v1.1.0" Foreground="#45AFFF"/>
                        </TextBlock>
                        <Button Content="检查更新" Click="CheckUpdate_Click" Margin="15,0,0,0" Padding="10,2" Height="26" FontSize="12" Background="#E3F2FD" Foreground="#45AFFF" BorderBrush="#45AFFF" BorderThickness="1" Cursor="Hand">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="深度复刻《蔚蓝档案》UI 风格动效的鼠标特效工具" Foreground="#666" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <Border Background="#FFF0F0" CornerRadius="6" Padding="12" Margin="0,0,0,20" BorderBrush="#FFCCCC" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️" Margin="0,0,8,0" VerticalAlignment="Top"/>
                            <TextBlock Text="安全提示：请务必确保从 GitHub 官方仓库下载。第三方分发渠道的版本可能存在报毒风险或恶意篡改。" Foreground="#CC0000" FontSize="12" TextWrapping="Wrap" MaxWidth="380"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="如果你喜欢本应用，欢迎支持开发者持续维护 ☕" Foreground="#45AFFF" Margin="0,0,0,25"/>
                    
                    <Button Content="🌐 访问 GitHub 官方仓库" Tag="https://github.com/DoomVoss/BASpark" Click="OpenLink_Click" Width="220" Height="38" Background="#333" Foreground="White" BorderThickness="0" HorizontalAlignment="Left" Cursor="Hand" Margin="0,0,0,10"/>
                    <Button Content="📺 关注 B 站官号" Tag="https://space.bilibili.com/3493116084488813" Click="OpenLink_Click" Width="220" Height="38" Background="#FB7299" Foreground="White" BorderThickness="0" HorizontalAlignment="Left" Cursor="Hand" Margin="0,0,0,10"/>
                    <Button Content="💬 加入 QQ 交流群" Tag="https://qm.qq.com/q/lgvVto3yPm" Click="OpenLink_Click" Width="220" Height="38" Background="#12B7F5" Foreground="White" BorderThickness="0" HorizontalAlignment="Left" Cursor="Hand" Margin="0,0,0,10"/>
                    <Button Content="☕ 赞助支持作者" Tag="https://qq.catbotstudio.top/jrys/spor.png" Click="OpenLink_Click" Width="220" Height="38" Background="#FF8140" Foreground="White" BorderThickness="0" HorizontalAlignment="Left" Cursor="Hand" Margin="0,0,0,30"/>

                    <TextBlock Text="开发者选项" FontSize="14" FontWeight="Bold" Foreground="#999" Margin="0,15,0,10"/>
                    <Button Content="重置所有设置并退出" Click="ResetConfig_Click" Background="#FFE0E0" Foreground="#CC0000" BorderThickness="0" HorizontalAlignment="Left" Padding="15,8" Cursor="Hand"/>
                </StackPanel>
                
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>